# Spectrum Game – Server Environment Variables
# Copy this file to server/.env and fill in the values.
# Never commit the real .env file to version control.

# ── Server ──────────────────────────────────────────────────────────────────

# TCP port the Node.js server listens on.
# Default: 3000
PORT=3000

# Allowed CORS origin for socket.io.  Use '*' to allow all (development) or
# set to your domain in production (e.g. https://game.example.com).
# Default: *
CORS_ORIGIN=https://game.example.com

# ── Admin dashboard (/nimda) ─────────────────────────────────────────────────

# Password that protects the /nimda admin dashboard.
# Change this to a strong random value before going live.
NIMDA_PASSWORD=change_me_to_something_strong

# ── Rate limiting ────────────────────────────────────────────────────────────

# Maximum number of attack events a single socket may send per second.
# Excess events are silently dropped.  Increase if legitimate players feel
# unresponsive; decrease to tighten protection against flooding.
# Default: 10
ATTACK_RATE_LIMIT=10

# ── Session cleanup ──────────────────────────────────────────────────────────

# Idle sessions older than this many minutes are removed from memory.
# Default: 30
SESSION_IDLE_MINUTES=30

# ── Horizontal scaling (optional, requires Redis) ────────────────────────────

# When set, the server uses the @socket.io/redis-adapter so multiple Node.js
# processes (PM2 cluster mode) can share socket.io rooms.
# Leave blank to run in single-process mode (no Redis needed).
# Example: redis://127.0.0.1:6379
REDIS_URL=
